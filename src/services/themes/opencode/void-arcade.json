{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#0d0014",
    "panel": "#150022",
    "element": "#1f0033",
    "border": "#3a0a5a",
    "borderActive": "#5a1a8a",
    "text": "#ffeaff",
    "textMuted": "#a88bc8",
    "magenta": "#ff2bbb",
    "magentaLight": "#ff7fd8",
    "cyan": "#00eaff",
    "neon": "#39ff14",
    "amber": "#ffd600",
    "red": "#ff1744",
    "purple": "#b928ff",
    "violet": "#d18cff"
  },
  "theme": {
    "primary": { "dark": "magenta", "light": "magenta" },
    "secondary": { "dark": "cyan", "light": "cyan" },
    "accent": { "dark": "violet", "light": "violet" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "amber", "light": "amber" },
    "success": { "dark": "neon", "light": "neon" },
