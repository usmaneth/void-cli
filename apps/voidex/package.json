{
  "name": "@void-cli/voidex",
  "private": true,
  "version": "0.1.0",
  "description": "Voidex — the Void desktop app (Electron). Forked from opencode-electron.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/usmaneth/void-cli",
  "author": {
    "name": "void-cli contributors",
    "email": "noreply@example.com"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "package": "electron-builder --config electron-builder.config.cjs",
    "package:mac": "electron-builder --mac --config electron-builder.config.cjs",
    "package:win": "electron-builder --win --config electron-builder.config.cjs",
    "package:linux": "electron-builder --linux --config electron-builder.config.cjs",
    "test:e2e": "playwright test"
  },
  "main": "./out/main/index.js",
  "dependencies": {
    "@void-cli/voidex-app": "workspace:*",
    "@void-cli/voidex-ui": "workspace:*",
    "electron-log": "^5.2.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.3",
    "marked": "^15.0.0",
    "solid-js": "1.9.10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "playwright": "^1.50.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-solid": "2.11.10"
  }
}
