#!/usr/bin/env bash
# Void CLI launcher
# Supports both bun (fast, dev) and node (production) runtimes.

SCRIPT_PATH="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Always run from the project root — bun/node module resolution and
# Ink's terminal handling can hang when CWD is outside the project
# (e.g., running `void` from ~). The entrypoint reads VOID_LAUNCH_CWD
# to know the user's original working directory.
export VOID_LAUNCH_CWD="$PWD"
cd "$ROOT_DIR"

# If bun is available, use it directly on the TypeScript source (faster, no build needed)
if command -v bun >/dev/null 2>&1; then
  exec bun ./src/entrypoints/cli.tsx "$@"
fi

# Fall back to Node.js with the compiled dist
if [ ! -d "$ROOT_DIR/dist" ]; then
  echo "Error: dist/ not found. Run 'npm run build' first." >&2
  exit 1
fi

exec node --import "$ROOT_DIR/scripts/register-loader.js" "$ROOT_DIR/dist/entrypoints/cli.js" "$@"
