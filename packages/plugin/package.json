{
  "name": "@void-cli/plugin",
  "version": "0.1.0",
  "description": "Typed TypeScript SDK for authoring Void CLI plugins (tools, skills, keybinds, hooks)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "zod": ">=3.22 <5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "void-cli",
    "plugin",
    "sdk",
    "cli",
    "ai",
    "agent"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
